    <limit lower="-0.8" upper="0.8" effort="10" velocity="2.0"/>
    <dynamics damping="0.05" friction="0.001"/>
    <mimic joint="left_gear_arm_3_joint" multiplier="-1" offset="0"/>
  </joint>

  <!-- Right outer finger: axis -Y, mirrors right gear → multiplier=-1 -->
  <joint name="right_outer_finger_arm_3_joint" type="revolute">
    <origin xyz="0.030286 0.014 -0.073739" rpy="0 0 0"/>
    <parent link="arm_3_1"/>
    <child link="right_finger_outer_link_1"/>
