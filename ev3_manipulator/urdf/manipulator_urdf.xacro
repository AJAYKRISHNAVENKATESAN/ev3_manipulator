  <!-- ══════════════════════════════════════════════════════════════════════
       JOINTS
  ══════════════════════════════════════════════════════════════════════ -->

  <!-- ── ARM JOINTS — unchanged ─────────────────────────────────────────── -->

  <joint name="arm_1_base_link_joint" type="revolute">
    <origin xyz="-0.020125 0.103583 0.094" rpy="0 0 0"/>
