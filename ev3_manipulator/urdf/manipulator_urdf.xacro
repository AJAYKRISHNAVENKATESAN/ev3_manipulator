    <axis xyz="1.0 0.0 0.0"/>
    <limit lower="-1.5708" upper="1.5708" effort="50" velocity="1.5"/>
    <dynamics damping="1.0" friction="0.2"/>
    <mimic joint="arm_2_left_arm_linkage_joint" multiplier="-1" offset="0"/>
  </joint>

  <joint name="arm_3_arm_2_connector_fixed_joint" type="fixed">
    <origin xyz="0.007501 0.002912 -0.045631" rpy="0 0 0"/>
    <parent link="arm_2_connector_1"/>
    <child link="arm_3_1"/>
  </joint>

  <!-- ── GRIPPER JOINTS — updated origins from redesign ─────────────────── -->

  <!-- Master gripper — commanded by controller -->
  <joint name="left_gear_arm_3_joint" type="revolute">
    <origin xyz="0.000286 0.042683 -0.073739" rpy="0 0 0"/>
    <parent link="arm_3_1"/>
    <child link="left_gear_link_1"/>
    <axis xyz="0.0 -1.0 0.0"/>
    <limit lower="-0.8" upper="0.8" effort="15" velocity="2.0"/>
    <dynamics damping="0.1" friction="0.005"/>
  </joint>

  <!-- Left inner finger: same axis as master → multiplier=1 -->
  <joint name="left_inner_finger_arm_3_joint" type="revolute">
    <origin xyz="-0.029696 0.038683 -0.073739" rpy="0 0 0"/>
    <parent link="arm_3_1"/>
    <child link="left_finger_inner_link_1"/>
    <axis xyz="0.0 -1.0 0.0"/>
    <limit lower="-0.8" upper="0.8" effort="10" velocity="2.0"/>
    <dynamics damping="0.05" friction="0.001"/>
    <mimic joint="left_gear_arm_3_joint" multiplier="-1" offset="0"/>
  </joint>

  <!-- Left outer finger: axis FLIPPED to +Y in new design → multiplier=-1 -->
  <joint name="left_outer_finger_arm_3_joint" type="revolute">
    <origin xyz="0.030286 0.038683 -0.073739" rpy="0 0 0"/>
    <parent link="arm_3_1"/>
    <child link="left_finger_outer_link_1"/>
    <axis xyz="0.0 1.0 0.0"/>
    <limit lower="-0.8" upper="0.8" effort="10" velocity="2.0"/>
    <dynamics damping="0.05" friction="0.001"/>
    <mimic joint="left_gear_arm_3_joint" multiplier="1" offset="0"/>
  </joint>

  <!-- Right gear: axis CHANGED to -Y in new design → multiplier=-1 to mirror -->
  <joint name="right_gear_arm_3_joint" type="revolute">
    <origin xyz="0.000286 0.009683 -0.073739" rpy="0 0 0"/>
    <parent link="arm_3_1"/>
    <child link="right_gear_link_1"/>
    <axis xyz="0.0 -1.0 0.0"/>
    <limit lower="-0.8" upper="0.8" effort="15" velocity="2.0"/>
    <dynamics damping="0.1" friction="0.005"/>
    <mimic joint="left_gear_arm_3_joint" multiplier="-1" offset="0"/>
  </joint>

  <!-- Right inner finger: axis -Y, mirrors right gear → multiplier=-1 -->
  <joint name="right_inner_finger_arm_3_joint" type="revolute">
    <origin xyz="-0.029696 0.014 -0.073739" rpy="0 0 0"/>
    <parent link="arm_3_1"/>
    <child link="right_finger_inner_link_1"/>
