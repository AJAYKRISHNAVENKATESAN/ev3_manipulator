    <child link="arm_1_1"/>
    <axis xyz="0.0 0.0 -1.0"/>
    <limit lower="-3.14159" upper="3.14159" effort="80" velocity="1.5"/>
    <dynamics damping="2.0" friction="0.5"/>
  </joint>

  <joint name="left_arm_linkage_arm_1_joint" type="fixed">
    <origin xyz="-0.035 -0.065466 0.110384" rpy="0 0 0"/>
    <parent link="arm_1_1"/>
